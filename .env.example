# Replicate API for Whisper transcription (V1 API)
REPLICATE_API_TOKEN=

# OpenAI API for GPT-4o transcription (V3 API)
OPENAI_API_KEY=

# Firebase service account (base64 encoded) - for Railway deployment
# Generate with: base64 -i service_account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Parallel processing workers (optional)
MAX_PREPARATION_WORKERS=5
MAX_CHUNK_WORKERS=10
